# Local environment variables - DO NOT COMMIT TO GIT
# Copy from your existing configuration and add your actual API keys here

# OpenWeatherMap API for weather data

EXPO_PUBLIC_OPENWEATHER_GEOCODING_URL=
EXPO_PUBLIC_OPENWEATHER_ONECALL_URL=
EXPO_PUBLIC_OPENWEATHER_API_KEY=

# Google Places API for location autocomplete and geocoding
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY= 
EXPO_PUBLIC_GOOGLE_GEOCODING_URL=https://maps.googleapis.com/maps/api/geocode/json
EXPO_PUBLIC_GOOGLE_REVERSE_GEOCODING_URL=https://maps.googleapis.com/maps/api/geocode/json

# Gemini API for outfit generation
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_API_URL=
   
# Supabase configuration for authentication and database
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=