# Supabase Configuration
# Copy this file to .env.local and fill in your Supabase project details
# You can find these values in your Supabase project settings

# Your Supabase project URL
EXPO_PUBLIC_SUPABASE_URL=https://.supabase.co

# Your Supabase anonymous public key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenWeatherMap API Key (for weather integration)
EXPO_PUBLIC_OPENWEATHER_API_KEY=your-openweather-api-key-here
EXPO_PUBLIC_OPENWEATHER_WEATHER_URL=
EXPO_PUBLIC_OPENWEATHER_GEOCODING_URL=
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

EXPO_PUBLIC_GEMINI_KEY=your-key-here