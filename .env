# Environment variables for Sun Dressed app
# These are public variables that will be bundled with the app

# OpenWeatherMap API for weather data
EXPO_PUBLIC_OPENWEATHER_API_KEY=
EXPO_PUBLIC_OPENWEATHER_WEATHER_URL=
EXPO_PUBLIC_OPENWEATHER_GEOCODING_URL=
# Google Places API for location autocomplete  
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Supabase configuration for authentication and database
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EOF < /dev/null
