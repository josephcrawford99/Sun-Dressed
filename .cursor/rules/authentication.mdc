## Data Management

### User Data
```typescript
interface User {
  id: string;
  email: string;
  name: string;
  preferences: UserPreferences;
  createdAt: Date;
  lastLogin: Date;
}

interface UserPreferences {
  stylePreference: 'masculine' | 'feminine' | 'neutral';
  temperatureUnit: 'C' | 'F';
  windSpeedUnit: 'ms' | 'mph';
}
```

